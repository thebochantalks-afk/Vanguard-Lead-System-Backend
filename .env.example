# Vanguard Growth Backend - Environment Variables

# Server
PORT=3001

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Interakt WhatsApp (Indian BSP)
# Sign up at https://interakt.ai, get API key from dashboard
INTERAKT_API_KEY=your-interakt-api-key
INTERAKT_COUNTRY_CODE=+91
INTERAKT_VERIFY_TOKEN=your-interakt-webhook-verify-token

# Meta Ads (Facebook/Instagram)
META_VERIFY_TOKEN=your-meta-webhook-verify-token
META_APP_SECRET=your-meta-app-secret

# API Auth (simple token-based auth for internal routes)
API_AUTH_TOKEN=your-secret-api-token

# Webhook Security
WEBHOOK_LEAD_TOKEN=your-secret-lead-ingestion-token

# Redis (for BullMQ job queue)
REDIS_URL=redis://127.0.0.1:6379
